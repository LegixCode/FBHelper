{
    "version": "1.21.2",
    "manifest_version": 2,
    "description": "Мультитул для FB, объединивший в себе прокси, юзерагенты и информацию о статусе рекламы. Developed by Legix for Syndicate",
    "name": "FBHelper",
    "icons": {
        "128": "images/icon_128.png",
        "48": "images/icon_48.png",
        "16": "images/icon_16.png"
    },
    "permissions": [
        "cookies",
        "proxy",
        "webRequest",
        "webRequestBlocking",
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "browser_action": {
        "default_popup": "popup.html"
    }
}